  "about": {
    "title": "關於 Petit Stay",
    "intro1": "Petit Stay 是為造訪首爾的家庭打造的優質保姆媒合平台。",
    "intro2": "旅行中要找到值得信賴的托育服務並不容易，Petit Stay 為您解決這個煩惱。",
    "intro3": "所有保姆均通過身份驗證、經歷確認及背景調查，並精通多種語言。從預約到付款、照護報告，所有流程都在同一個平台上輕鬆完成。",
    "roleTitle": "我們的角色",
    "roleDesc": "Petit Stay 不直接僱用保姆。我們將經過驗證的獨立保姆與家庭連結在一起，飯店和住宿設施則以推薦合作夥伴的身份參與。",
    "promiseTitle": "我們的承諾",
    "promiseDesc": "安心的托育，愉快的夜晚。這就是 Petit Stay 的承諾。",
    "contactTitle": "聯繫我們",
    "contactEmail": "hello@petitstay.com"
  },
  "help": {
    "title": "常見問題",
    "q1": "Petit Stay 是什麼服務？",
    "a1": "Petit Stay 為造訪首爾的家庭提供經過驗證的保姆媒合服務，專注於飯店客房內的晚間托育。",
    "q2": "保姆如何通過驗證？",
    "a2": "所有保姆均通過身份驗證、托育經歷確認及背景調查。相關證照（CPR、急救等）也會顯示在個人檔案中。",
    "q3": "服務時間是幾點到幾點？",
    "a3": "基本服務時間為 18:00 至 23:00。建議至少提前 24 小時預約。",
    "q4": "孩子有年齡限制嗎？",
    "a4": "服務對象為 3 歲至 8 歲的兒童。",
    "q5": "如何付款？",
    "a5": "預約時以信用卡付款，保姆確認前不會實際扣款。採用安全支付方式。",
    "q6": "可以取消預約嗎？",
    "a6": "服務開始前 24 小時可免費取消。之後取消可能會收取手續費。",
    "q7": "保姆不提供哪些服務？",
    "a7": "保姆不提供過夜照護、泳池/海灘看護、車輛接送及用藥管理。",
    "q8": "如果發生問題怎麼辦？",
    "a8": "請聯繫 help@petitstay.com，我們會盡快為您處理。"
  },
  "privacy": {
    "title": "隱私權政策",
    "lastUpdated": "最後更新：2026 年 3 月",
    "intro": "Petit Stay（以下簡稱「本公司」）重視用戶的個人資訊，並依據相關法規合法處理。",
    "section1Title": "收集的個人資訊",
    "section1": "電子郵件、姓名、電話號碼、付款資訊（卡片資訊由 Stripe 安全管理）、預約紀錄、孩子資訊（姓名、年齡、特殊需求）",
    "section2Title": "收集目的",
    "section2": "服務提供與預約管理、保姆媒合與安全管理、付款處理、客戶支援、服務改善",
    "section3Title": "第三方提供",
    "section3": "預約確認後，孩子的資訊與聯絡方式將提供給保姆。付款透過 Stripe 處理，本公司不直接儲存卡號。",
    "section4Title": "保存期限",
    "section4": "帳號註銷時個人資訊將立即刪除。但若法律要求保存，則在法定期限內保管。",
    "section5Title": "用戶權利",
    "section5": "您可以請求查閱、修正或刪除個人資訊。請聯繫 help@petitstay.com。",
